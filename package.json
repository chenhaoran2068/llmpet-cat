{
  "name": "llmpet-cat",
  "version": "0.10.58",
  "description": "陪你使用 Codex 的猫猫桌宠",
  "main": "main.js",
  "license": "MIT",
  "author": "Chenaoran",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "start": "electron .",
    "package:win": "electron-builder --win --publish never",
    "package:mac": "electron-builder --mac --universal --publish never",
    "test": "node test/core.js && node test/codex-watcher.js && node test/kimi-desktop-watcher.js && node test/project-state.js && node test/work-source-presence.js && node test/window-placement.js && node test/office-motion-assets.js && node test/office-layout.js && node test/office-management-sync.js && node test/high-frame-actions.js && node test/office-open-target.js && node test/preferences-removed.js"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.myunwang.octopus",
    "productName": "LLMPET Cat",
    "copyright": "Copyright © 2026 Chenaoran",
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "LICENSE",
      "PRIVACY.md",
      "README.md",
      "backend/config.js",
      "backend/core.js",
      "backend/codex-watcher.js",
      "backend/kimi-desktop-watcher.js",
      "backend/work-target.js",
      "backend/work-source-presence.js",
      "backend/window-placement.js",
      "backend/log.js",
      "renderer/pet.html",
      "renderer/pet.css",
      "renderer/project-state.js",
      "renderer/pet.js",
      "renderer/munch.html",
      "renderer/munch.css",
      "renderer/munch.js",
      "renderer/break.html",
      "renderer/break.css",
      "renderer/break.js",
      "assets/cat/cat-belly-play.png",
      "assets/cat/cat-belly-wave.png",
      "assets/cat/cat-belly-roll.png",
      "assets/cat/*.gif",
      "!assets/cat/qq-post-2026-05-29/**",
      "assets/cat/office-scene/actions/programmer/*.webp",
      "assets/cat/office-scene/actions/writer/*.webp",
      "assets/cat/office-scene/actions/chubby/*.webp",
      "assets/cat/office-scene/desks/plain.png",
      "assets/cat/office-scene/desks/programmer.png",
      "assets/cat/office-scene/desks/writer.png",
      "assets/cat/office-scene/desks/chubby.png",
      "assets/icon.ico",
      "assets/icon.icns",
      "assets/tray.png",
      "assets/tray@2x.png"
    ],
    "win": {
      "target": ["nsis", "zip"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "artifactName": "LLMPET-Cat-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "LLMPET-Cat-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  }
}
